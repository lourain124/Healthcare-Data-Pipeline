# Copia este archivo como `.env` y ajusta valores (`.env` no se versiona).

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Validacion de salida final (processed): filas minimas
MIN_FINAL_ROWS=1

# Si es false, falla si queda algun NaN tras la imputacion (comprobacion extra).
# Por defecto ``processed`` imputa todos los nulos antes de guardar; suele ser seguro poner false.
ALLOW_FINAL_NULLS=false

# Columnas que deben existir tras finalize (separadas por coma). Vacio = no comprobar nombres.
# FINAL_REQUIRED_COLUMNS=col_0,col_1
